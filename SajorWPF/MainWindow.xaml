<Window x:Class="SajorIPT101Solution.SajorWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:SajorIPT101Solution.SajorWPF.Models"
        mc:Ignorable="d"
        Title="Employee" Height="450" Width="800">
    <Grid Background="#FFD75F5F" Margin="10">
        <!-- Inputs -->
        <Label Content="First Name:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,0,0,0"/>
        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,0,0,0"/>

        <Label Content="Last Name:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,35,0,0"/>
        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,35,0,0"/>

        <Label Content="Age:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,70,0,0"/>
        <TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged}" Width="50" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,70,0,0"/>

        <Label Content="Position:" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,105,0,0"/>
        <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}" Width="150" Height="25" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,105,0,0"/>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,140,0,0">
            <Button Content="Add" Width="80" Height="30" Margin="0,0,10,0" Command="{Binding AddCommand}"/>
            <Button Content="Edit" Width="80" Height="30" Margin="0,0,10,0" Command="{Binding EditCommand}"/>
            <Button Content="Update" Width="80" Height="30" Margin="0,0,10,0" Command="{Binding UpdateCommand}"/>
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" Command="{Binding CancelCommand}"/>
            <Button Content="Delete" Width="80" Height="30" Command="{Binding DeleteCommand}"/>
        </StackPanel>

        <TextBlock HorizontalAlignment="Right" Margin="420,10,0,0" TextWrapping="Wrap" Text="Employee System" VerticalAlignment="Top" Height="115" Width="338" FontSize="40"/>

        <!-- List -->
        <ListBox ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}" Margin="0,200,0,0">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:Employee}">
                    <Border Padding="8" Margin="4" Background="White" CornerRadius="4">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,4">
                                <Run Text="FirstName: "/>
                                <Run Text="{Binding FirstName}"/>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,4">
                                <Run Text="LastName: "/>
                                <Run Text="{Binding LastName}"/>
                            </TextBlock>
                            <TextBlock Margin="0,0,0,4">
                                <Run Text="Age: "/>
                                <Run Text="{Binding Age}"/>
                            </TextBlock>
                            <TextBlock>
                                <Run Text="Position: "/>
                                <Run Text="{Binding Position}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>